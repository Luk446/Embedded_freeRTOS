flowchart TD
	A[app_main starts] --> B[monitorInit]
	B --> C[gpio_init<br/>configure SYNC and IN_S ISRs<br/>configure ACK outputs]
	C --> D[pcnt_init<br/>start hardware edge counters for IN_A and IN_B]
	D --> E[Wait for first SYNC rising edge]
	E --> F[Capture T0]
	F --> G[reset_schedule_state T0<br/>reset task indices, tokens, PCNT baselines<br/>reset local monitor state]
	G --> H[synch helper monitor<br/>set schedule_started true]
	H --> I[Enter cyclic executive]

	I --> J[Wait until next_frame_start]
	J --> K[slot = frame_counter mod 10<br/>frame_end = next_frame_start + 10 ms]
	K --> L[latch_counts_for_slot<br/>A every frame<br/>B every even frame]
	L --> M[run_slot slot]
	M --> N[run_sporadic_if_budget<br/>run S only while slack remains]
	N --> O[sched_monitor_queue_due_report]
	O --> P{slot == 5?}
	P -- yes --> Q[sched_monitor_service_line<br/>print one MON line if enough slack remains]
	P -- no --> R[Skip monitor line this frame]
	Q --> S[Check frame overrun and throttle warning logs]
	R --> S
	S --> T[Idle until frame_end]
	T --> U[frame_counter++<br/>next_frame_start += 10 ms]
	U --> I

	subgraph SlotMap[Fixed 100 ms Major Cycle]
		SM0[0: A, B, AGG]
		SM1[1: A, C]
		SM2[2: A, B, AGG]
		SM3[3: A, D]
		SM4[4: A, B, AGG]
		SM5[5: A<br/>free frame for S and monitor line]
		SM6[6: A, B, AGG]
		SM7[7: A, C]
		SM8[8: A, B, AGG]
		SM9[9: A, D]
	end

	M -. dispatch uses .-> SlotMap

	subgraph TaskPattern[Task Execution Pattern]
		TP1[Compute release time and seed]
		TP2[Begin local monitor task timing]
		TP3[Begin helper monitor task timing]
		TP4[ACK high]
		TP5[Run WorkKernel with task budget]
		TP6[ACK low]
		TP7[End helper monitor task timing]
		TP8[End local monitor task timing]
		TP9[Update token or count state]
	end

	M -. each task follows .-> TaskPattern
	N -. sporadic task follows .-> TaskPattern

	subgraph Reporting[Local Scheduler-Friendly Monitor Output]
		RP1[Every 4 s capture local monitor snapshot]
		RP2[Store pending report state]
		RP3[During slot 5 print one line only<br/>T0 then A then B then AGG then C then D then S]
	end

	O -. queues .-> Reporting
	Q -. drains .-> Reporting

	subgraph ISRSide[ISR Side Events]
		SY[[ISR SYNC]] --> SY1{sync_seen already?}
		SY1 -- no --> SY2[Latch sync time and set sync_seen]
		SY1 -- yes --> SY3[Ignore]

		SS[[ISR IN_S]] --> SS1{schedule_started?}
		SS1 -- yes --> SS2[pending_s++<br/>queue local S release time<br/>notifySRelease helper monitor]
		SS1 -- no --> SS3[Ignore]

		SA[[IN_A edges]] --> SA1[Counted by PCNT hardware]
		SB[[IN_B edges]] --> SB1[Counted by PCNT hardware]
	end
